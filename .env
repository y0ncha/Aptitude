# ---------------------------
# Database Configuration
# ---------------------------

# PostgreSQL credentials
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=Aptitude
DB_HOST=postgres
DB_PORT=5432

# Use the PostgreSQL service name from docker-compose for the hostname
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/aptitude

# Service Configuration
SERVICE_NAME=aptitude-service
SERVICE_VERSION=0.1.0

# Alembic Configuration
ALEMBIC_CONFIG_PATH=alembic.ini

